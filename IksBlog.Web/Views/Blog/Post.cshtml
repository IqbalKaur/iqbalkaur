@model BlogPost
@{
    ViewData["Title"] = Model.PostTitle;
}

<article>
    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1">
                <h2 class="subheading">@Model.PostSubTitle</h2>
                <span class="meta">
                    Posted by <a href="#">@Model.Author.UserName</a>
                    on @DateDisplayHelper.FormatUtcToEst(Model.CreatedAt)
                </span>

                <div class="content">@Html.Raw(Model.Content)</div>
                <hr />

                <h2 id="comments">Comments</h2>
                @foreach (var item in Model.Comments)
                {
                    <div class="comment">
                        <h3 class="comment-content">@item.CommentText</h3>
                        <p class="comment-meta">By @item.Name</p>
                    </div>
                    <hr />
                }

                <p>Please leave your comment here!</p>
                <form asp-action="AddComment" method="post">
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <div class="row control-group">
                        <div class="form-group col-12 floating-label-form-group controls">
                            <label>Name:</label>
                            <input type="text" name="name" class="form-control" placeholder="Name" required />
                        </div>
                    </div>
                    <div class="row control-group">
                        <div class="form-group col-12 floating-label-form-group controls">
                            <label>Email:</label>
                            <input type="email" name="email" class="form-control" placeholder="Email" required />
                        </div>
                    </div>
                    <div class="row control-group">
                        <div class="form-group col-12 floating-label-form-group controls">
                            <label>Comment:</label>
                            <textarea name="comment" class="form-control" rows="5" placeholder="Your Comments" required></textarea>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-12">
                            <button type="submit" class="btn btn-default">Post Comment</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</article>

<hr />
